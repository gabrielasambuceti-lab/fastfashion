<script src="https://cdn.jsdelivr.net/npm/reveal.js@5/dist/reveal.js"></script>
<script>
const state={budget:0,env:0,social:0,top:null,pants:null,shoes:null,stopAtSurprise:false,stopAtFinalCheck:false};
const tops=[
{id:'top-a',name:'Top blanco básico',price:9.99,env:1,social:1,desc:'Ruta de fast fashion barato.',consTitle:'Consecuencia Top A',consCopy:'Micro-video: fábrica / trabajo precario. Presupuesto - 9,99. Impacto ambiental +1.',tags:['9,99 €','Fast fashion barato'],img:'data:image/jpeg;base64,'},
{id:'top-b',name:'Top rosa drapeado',price:19.99,env:1,social:1,desc:'Ruta de fast fashion “mejor calidad” o más aspiracional.',consTitle:'Consecuencia Top B',consCopy:'Micro-video: marketing y calidad media. Presupuesto - 19,99. Impacto ambiental +1.',tags:['19,99 €','Calidad media'],img:'data:image/jpeg;base64,'},
{id:'top-c',name:'Top verde básico',price:0,env:0,social:0,desc:'Ruta alternativa más consciente.',consTitle:'Consecuencia Top C',consCopy:'Micro-video: segunda mano / reutilizar. Presupuesto - 0. Impacto ambiental +0.',tags:['0 €','Alternativa'],img:'data:image/jpeg;base64,'}
];
const pants=[
{id:'pants-1',name:'1 puesta',env:2,social:0,tone:'high',copy:'Impacto muy alto por uso. Pantalón casi desechable.',result:'Uso 1 vez'},
{id:'pants-5',name:'5 puestas',env:1,social:0,tone:'mid',copy:'Impacto intermedio. Lo usarás algunas veces.',result:'Uso medio'},
{id:'pants-20',name:'20+ puestas',env:0,social:0,tone:'low',copy:'Impacto por uso más bajo. Prenda de largo recorrido.',result:'Uso intensivo'}
];
const shoes=[
{id:'shoe-fast',name:'Comprarlos nuevos en fast fashion',price:24.99,env:2,social:0,desc:'Sube mucho el impacto por materiales, producción y residuos.',consTitle:'Consecuencia zapatos – fast fashion',consCopy:'Sube mucho el impacto. Actualiza variables: impacto ambiental ++.',tags:['Nuevo','Fast fashion']},
{id:'shoe-alt',name:'Buscarlos de segunda mano / compartir / reutilizar',price:0,env:0,social:0,desc:'Impacto más bajo al compartir o reutilizar.',consTitle:'Consecuencia zapatos – alternativa',consCopy:'Impacto más bajo: compartes o reutilizas. Actualiza variables: impacto bajo.',tags:['Reutilizar','Compartir']}
];
function money(v){return new Intl.NumberFormat('es-ES',{style:'currency',currency:'EUR'}).format(v)}
function totalScore(){return state.env+state.social}
function toast(t){const el=document.getElementById('toast');el.textContent=t;el.classList.add('show');clearTimeout(window.__tt);window.__tt=setTimeout(()=>el.classList.remove('show'),1500)}
function renderBag(id){const el=document.getElementById(id);if(!el)return;el.innerHTML=`<div class="bag-row"><div><span class="slot">Top</span><strong>${state.top?state.top.name:'Sin elegir'}</strong></div><div>${state.top?money(state.top.price):'—'}</div></div><div class="bag-row"><div><span class="slot">Pantalón</span><strong>${state.pants?state.pants.name:'Sin elegir'}</strong></div><div>${state.pants?state.pants.result:'—'}</div></div><div class="bag-row"><div><span class="slot">Zapatos</span><strong>${state.shoes?state.shoes.name:'Sin elegir'}</strong></div><div>${state.shoes?money(state.shoes.price):'—'}</div></div>`}
function renderStats(i){const b=document.getElementById('budget-'+i),e=document.getElementById('env-'+i),s=document.getElementById('social-'+i),m=document.getElementById('meter-'+i);if(b)b.textContent=money(state.budget);if(e)e.textContent=String(state.env);if(s)s.textContent=String(state.social);if(m)m.style.width=Math.min(100,totalScore()/5*100)+'%'}
function renderTops(){document.getElementById('top-grid').innerHTML=tops.map(o=>`<article class="card"><div class="product-photo"><img src="${o.img}" alt="${o.name}" /></div><div class="info"><div class="meta"><div class="name">${o.name}</div><div class="price">${money(o.price)}</div></div><p>${o.desc}</p><div class="tags">${o.tags.map(t=>`<span class="tag">${t}</span>`).join('')}</div><button class="option-btn ${state.top?.id===o.id?'selected':''}" data-top="${o.id}">${state.top?.id===o.id?'Elegido':'Seleccionar'}</button></div></article>`).join('');document.getElementById('next-top').disabled=!state.top}
function renderPants(){document.getElementById('pants-grid').innerHTML=pants.map(o=>`<article class="use-card" data-tone="${o.tone}"><div class="eyebrow">Consecuencia</div><h3>${o.name}</h3><p>${o.copy}</p><button class="option-btn ${state.pants?.id===o.id?'selected':''}" data-pants="${o.id}">${state.pants?.id===o.id?'Elegido':'Seleccionar ruta'}</button></article>`).join('');document.getElementById('next-pants').disabled=!state.pants}
function renderShoes(){document.getElementById('shoes-grid').innerHTML=shoes.map(o=>`<article class="use-card" data-tone="${o.id==='shoe-fast'?'high':'low'}"><div class="eyebrow">Ruta</div><h3>${o.name}</h3><p>${o.desc}</p><div class="tags">${o.tags.map(t=>`<span class="tag">${t}</span>`).join('')}</div><button class="option-btn ${state.shoes?.id===o.id?'selected':''}" data-shoe="${o.id}">${state.shoes?.id===o.id?'Elegido':'Seleccionar ruta'}</button></article>`).join('');document.getElementById('next-shoes').disabled=!state.shoes}
function renderConsequences(){document.getElementById('top-cons-title').textContent=state.top?state.top.consTitle:'Aún no hay decisión';document.getElementById('top-cons-copy').textContent=state.top?state.top.consCopy:'La consecuencia del top se activa en cuanto elijas una ruta.';document.getElementById('top-cons-budget').textContent=money(state.budget);document.getElementById('top-cons-env').textContent=String(state.env);document.getElementById('top-cons-social').textContent=String(state.social);document.getElementById('shoe-cons-title').textContent=state.shoes?state.shoes.consTitle:'Aún no has elegido ruta';document.getElementById('shoe-cons-copy').textContent=state.shoes?state.shoes.consCopy:'Selecciona una opción para activar la consecuencia de zapatos.';document.getElementById('shoe-cons-budget').textContent=money(state.budget);document.getElementById('shoe-cons-env').textContent=String(state.env);document.getElementById('shoe-cons-social').textContent=String(state.social)}
function ending(){if(state.stopAtSurprise||state.stopAtFinalCheck)return{k:'B',title:'Final B – En transición',pill:'Paraste antes del final',copy:'Empiezas a alargar la vida de tus prendas, pero aún compras más de lo que necesitas.',img:'data:image/jpeg;base64,'};const sc=totalScore();if(sc>=4)return{k:'A',title:'Final A – Desastre',pill:'Impacto muy alto',copy:'Tu outfit termina aquí: paisaje textil, etiquetas intactas y ropa casi sin usar.',img:'data:image/jpeg;base64,'};if(sc>=2)return{k:'B',title:'Final B – En transición',pill:'Impacto medio',copy:'Empiezas a alargar la vida de tus prendas, pero aún compras más de lo que necesitas.',img:'data:image/jpeg;base64,'};return{k:'C',title:'Final C – Rebelde slow fashion',pill:'Impacto bajo',copy:'Planificas, reutilizas y eliges menos, pero mejor: tu armario deja de ser desechable.',img:'data:image/jpeg;base64,'}}
function renderFinal(){const rec=document.getElementById('receipt');rec.innerHTML=`<div class="receipt-row"><span>Top</span><strong>${state.top?state.top.name:'Sin elegir'}</strong></div><div class="receipt-row"><span>Pantalón</span><strong>${state.pants?state.pants.name:'Sin elegir'}</strong></div><div class="receipt-row"><span>Zapatos</span><strong>${state.shoes?state.shoes.name:(state.stopAtFinalCheck?'No añadidos':'Sin elegir')}</strong></div>`;document.getElementById('final-budget').textContent=money(state.budget);document.getElementById('final-env').textContent=String(state.env);document.getElementById('final-social').textContent=String(state.social);const e=ending();const box=document.getElementById('ending-images');if(box&&e.img){box.innerHTML=`<div class="impact-card" style="grid-column:1 / -1;text-align:center;"><img src="${e.img}" alt="${e.title}" style="max-width:100%;max-height:260px;object-fit:cover;border-radius:16px;"></div>`;}document.getElementById('ending-title').textContent=e.title;document.getElementById('ending-copy').textContent=e.copy;document.getElementById('ending-pill').textContent=e.pill;document.getElementById('ending-pill').style.background=e.k==='A'?'color-mix(in srgb,var(--red) 24%, var(--surface))':e.k==='B'?'color-mix(in srgb,var(--yellow) 24%, var(--surface))':'color-mix(in srgb,var(--blue) 24%, var(--surface))';document.getElementById('closure-title').textContent=e.title;document.getElementById('closure-copy').textContent=e.copy;var cimg=document.getElementById('closure-photo-img');if(cimg&&e.img){cimg.src=e.img;}document.getElementById('closure-top').textContent=state.top?state.top.name:'—';document.getElementById('closure-pants').textContent=state.pants?state.pants.name:'—';document.getElementById('closure-shoes').textContent=state.shoes?state.shoes.name:(state.stopAtFinalCheck?'No se llegó a elegir':'—');document.getElementById('closure-visual').style.background=e.k==='A'?'linear-gradient(135deg,#d8b2ab 0%,#b57266 50%,#4d211a 100%)':e.k==='B'?'linear-gradient(135deg,#ebe1b9 0%,#cfb962 50%,#695715 100%)':'linear-gradient(135deg,#d3e0f1 0%,#91b5e0 50%,#355b8d 100%)'}
function renderAll(){['bag-0','bag-1','bag-2','bag-3','bag-4','bag-5','bag-6','bag-7'].forEach(renderBag);['0','1','2','3','4','5','6','7'].forEach(renderStats);renderTops();renderPants();renderShoes();renderConsequences();renderFinal()}
function selectTop(id){const o=tops.find(x=>x.id===id);state.top=o;state.budget=o.price;state.env=o.env;state.social=o.social;state.pants=null;state.shoes=null;state.stopAtSurprise=false;state.stopAtFinalCheck=false;renderAll();toast('Top elegido')}
function selectPants(id){const o=pants.find(x=>x.id===id);state.pants=o;state.env=(state.top?state.top.env:0)+o.env;state.social=state.top?state.top.social:0;state.shoes=null;state.stopAtFinalCheck=false;renderAll();toast('Ruta de pantalón guardada')}
function selectShoe(id){const o=shoes.find(x=>x.id===id);state.shoes=o;const topEnv=state.top?state.top.env:0;const pantsEnv=state.pants?state.pants.env:0;state.budget=(state.top?state.top.price:0)+o.price;state.env=topEnv+pantsEnv+o.env;state.social=state.top?state.top.social:0;renderAll();toast('Ruta de zapatos guardada')}
function restart(){state.budget=0;state.env=0;state.social=0;state.top=null;state.pants=null;state.shoes=null;state.stopAtSurprise=false;state.stopAtFinalCheck=false;renderAll();deck.slide(0);toast('Juego reiniciado')}
const deck=new Reveal({controls:false,progress:true,center:false,touch:true,transition:'fade',backgroundTransition:'fade',width:'100%',height:'100%',margin:0,disableLayout:true});deck.initialize();renderAll();
document.addEventListener('click',e=>{const top=e.target.closest('[data-top]');if(top){deck.next();return;}const pantsBtn=e.target.closest('[data-pants]');if(pantsBtn){deck.next();return;}const shoe=e.target.closest('[data-shoe]');if(shoe){deck.next();return;}const theme=e.target.closest('[data-theme-toggle]');if(theme){const r=document.documentElement;r.setAttribute('data-theme',r.getAttribute('data-theme')==='dark'?'light':'dark');return;}if(e.target.matches('[data-next]'))deck.next();if(e.target.matches('[data-overview]'))deck.slide(10);if(e.target.id==='stop-here'){state.stopAtSurprise=true;renderAll();deck.slide(8);}if(e.target.id==='keep-going'){state.stopAtSurprise=false;renderAll();deck.slide(4);}if(e.target.id==='stop-before-shoes'){state.stopAtFinalCheck=true;state.shoes=null;renderAll();deck.slide(8);}if(e.target.id==='go-shoes'){state.stopAtFinalCheck=false;renderAll();deck.slide(6);}if(e.target.id==='restart-a'||e.target.id==='restart-b')restart();if(e.target.id==='back-final')deck.slide(8);if(e.target.id==='go-home')deck.slide(0)});

// simplified navigation, no auto-bounce

</script>
